# Required for the no-setup online demo.
AI_PROVIDER=mock
NEXT_PUBLIC_APP_NAME="AI Export Agent"
NEXT_PUBLIC_DEMO_MODE=true

# Optional: switch AI_PROVIDER=openai after adding a real key in Vercel.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Lead search:
# - SEARCH_PROVIDER=mock keeps the no-key demo mode.
# - SEARCH_PROVIDER=google-cse runs real public web search through Google Custom Search.
SEARCH_PROVIDER=mock
GOOGLE_CUSTOM_SEARCH_KEY=
GOOGLE_CUSTOM_SEARCH_CX=

# Optional future integrations. Keep blank for the Vercel smoke-test version.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
TRACKING_BASE_URL=
